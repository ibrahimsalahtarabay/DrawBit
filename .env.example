# Copy this file to .env and fill in your values
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/drawbit
# Render.com: provided automatically as DATABASE_URL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/drawbit

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
